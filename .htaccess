<IfModule mod_rewrite.c>
  RewriteEngine On
  RewriteBase /
  
  RewriteRule ^pricing/?$ https://iaccs.org.in/pricing.html [L,R=301]
  RewriteRule ^membership/?$ https://iaccs.org.in/membership.html [L,R=301]

  # 1. FIX THE ASSET PATHS
  # If any request contains "_next", ignore the directory prefix and serve from root
  # This turns "membership/_next/..." into "_next/..."
  RewriteRule ^.*?(_next/.*)$ $1 [L]

  # 2. STANDARD CHECKS
  # If the file or directory actually exists, serve it directly
  RewriteCond %{REQUEST_FILENAME} -f [OR]
  RewriteCond %{REQUEST_FILENAME} -d
  RewriteRule ^ - [L]

  # 3. FIX THE ROUTING (SPA Fallback)
  # If the file is missing, serve the ROOT index.html (not $1/index.html)
  RewriteRule ^ index.html [L]
</IfModule>

AddType application/javascript .js
AddType text/css .css

