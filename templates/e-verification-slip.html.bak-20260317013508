<!DOCTYPE html>
<html>
<head>
  <meta charset="utf-8" />
  <style>
    body { font-family: dejavusans, helvetica, sans-serif; font-size: 11pt; color: #111827; }
    .wrap { border: 1px solid #d1d5db; padding: 14px; }
    .title { font-size: 20pt; font-weight: bold; }
    .subtitle { font-size: 16pt; font-weight: bold; }
    .line { border-top: 1px solid #111827; margin: 10px 0; }
    .line-thick { border-top: 2px solid #111827; margin: 10px 0; }
    .meta { font-size: 9.5pt; }
    .addr { font-size: 9.5pt; text-align: center; }
    .slip { text-align: center; font-size: 18pt; font-weight: bold; letter-spacing: 0.5px; }
    .details { width: 100%; border-collapse: collapse; margin-top: 10px; }
    .details td { padding: 8px 4px; border-bottom: 1px solid #e5e7eb; vertical-align: top; }
    .label { width: 38%; font-weight: bold; }
    .value { width: 62%; }
    .footer { font-size: 8.5pt; color: #374151; margin-top: 14px; line-height: 1.35; }
  </style>
</head>
<body>
  <div class="wrap">
    <table width="100%" cellpadding="0" cellspacing="0">
      <tr>
        <td width="70" valign="middle">
          <img src="{{LOGO_SRC}}" width="60" />
        </td>
        <td valign="middle">
          <div class="title">The Association for Critical Care Sciences</div>
          <div class="subtitle">दि एसोसिएशन फ़ॉर क्रिटिकल केयर साइंसेज़</div>
        </td>
      </tr>
    </table>

    <div class="line-thick"></div>

    <table class="meta" width="100%" cellpadding="0" cellspacing="0">
      <tr>
        <td align="left">Registered as an AOP for regulatory purposes</td>
        <td align="center">www.iaccs.org.in</td>
        <td align="right">admin@iaccs.org.in</td>
      </tr>
    </table>

    <div class="line"></div>

    <div class="addr">Address:- 168, Mathkal, Nazrul Sarani, Dumdum Cantonment, Kolkata, 700065</div>

    <div class="line-thick"></div>

    <div class="slip">E-VERIFICATION SLIP</div>

    <table class="details" cellpadding="0" cellspacing="0">
      <tr><td class="label">Name:</td><td class="value">{{NAME}}</td></tr>
      <tr><td class="label">Membership ID:</td><td class="value">{{MEMBERSHIP_ID}}</td></tr>
      <tr><td class="label">Membership Category:</td><td class="value">{{MEMBERSHIP_CATEGORY}}</td></tr>
      <tr><td class="label">Membership Status:</td><td class="value">{{MEMBERSHIP_STATUS}}</td></tr>
      <tr><td class="label">Qualification:</td><td class="value">{{QUALIFICATION}}</td></tr>
      <tr><td class="label">Email:</td><td class="value">{{EMAIL}}</td></tr>
      <tr><td class="label">Contact Number:</td><td class="value">{{CONTACT_NUMBER}}</td></tr>
      <tr><td class="label">Membership Type:</td><td class="value">{{MEMBERSHIP_TYPE}}</td></tr>
      <tr><td class="label">Payment Status:</td><td class="value">{{PAYMENT_STATUS}}</td></tr>
      <tr><td class="label" style="border-bottom:none;">Valid Until:</td><td class="value" style="border-bottom:none;">{{VALID_UNTIL}}</td></tr>
    </table>

    <div class="footer">
      This E-Verification Slip is issued solely for internal membership identification purposes by The Association for
      Critical Care Sciences, an independent non-statutory professional body. It does not constitute, imply, or confer any
      statutory recognition, regulatory approval, governmental affiliation, accreditation, professional licensure, academic
      qualification, certification, or legal authority of any nature whatsoever.
    </div>
  </div>
</body>
</html>